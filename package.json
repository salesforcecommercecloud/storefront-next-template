{
    "name": "template-retail-rsc-app",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "react-router build",
        "bundlesize:test": "cross-env BUNDLES_SIZE_CHECK=true pnpm build",
        "bundlesize:analyze": "cross-env BUNDLES_SIZE_ANALYZE=true pnpm build",
        "dev": "react-router dev",
        "dev:debug": "NODE_OPTIONS='--inspect' react-router dev",
        "start": "cross-env NODE_ENV=development PORT=5173 node ./server ./build/server/index.js",
        "preview": "react-router build --mode=preview && pnpm start",
        "push": "storefront-next-dev push --project-directory .",
        "typecheck": "react-router typegen && tsc --noEmit",
        "test": "vitest run --coverage",
        "test:ui": "vitest --ui --coverage",
        "test:watch": "vitest",
        "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
        "lint:fix": "eslint . --fix",
        "lint:check-extensions": "node scripts/check-typescript-only.js",
        "lint:colors": "eslint src --ext .ts,.tsx,.js,.jsx --rule 'no-restricted-classnames: error'",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build",
        "lighthouse:ci": "lhci autorun"
    },
    "dependencies": {
        "@hookform/resolvers": "5.2.2",
        "@icons-pack/react-simple-icons": "13.7.0",
        "@radix-ui/react-accordion": "1.2.12",
        "@radix-ui/react-alert-dialog": "1.1.15",
        "@radix-ui/react-aspect-ratio": "1.1.7",
        "@radix-ui/react-avatar": "1.1.10",
        "@radix-ui/react-checkbox": "1.3.3",
        "@radix-ui/react-dialog": "1.1.15",
        "@radix-ui/react-dropdown-menu": "2.1.16",
        "@radix-ui/react-label": "2.1.7",
        "@radix-ui/react-navigation-menu": "1.2.14",
        "@radix-ui/react-popover": "1.1.15",
        "@radix-ui/react-radio-group": "1.3.8",
        "@radix-ui/react-select": "2.2.6",
        "@radix-ui/react-slot": "1.2.3",
        "@radix-ui/react-tooltip": "1.2.8",
        "@react-router/node": "7.9.2",
        "@salesforce/storefront-next-dev": "workspace:*",
        "@salesforce/storefront-next-runtime": "workspace:*",
        "class-variance-authority": "0.7.1",
        "clsx": "2.1.1",
        "commerce-sdk-isomorphic": "4.0.0-nightly-20251027080801",
        "embla-carousel-react": "8.6.0",
        "i18next": "25.5.3",
        "i18next-browser-languagedetector": "8.2.0",
        "i18next-fetch-backend": "6.0.0",
        "input-otp": "1.4.2",
        "isbot": "5.1.31",
        "jose": "6.1.0",
        "js-cookie": "3.0.5",
        "lodash.debounce": "4.0.8",
        "lucide-react": "0.544.0",
        "nanoid": "5.1.6",
        "react": "19.1.1",
        "react-dom": "19.1.1",
        "react-hook-form": "7.63.0",
        "react-i18next": "16.0.0",
        "react-router": "7.9.2",
        "remix-i18next": "7.4.2",
        "sonner": "2.0.7",
        "tailwind-merge": "3.3.1",
        "tailwindcss": "4.1.13",
        "vaul": "1.1.2",
        "zod": "4.1.11",
        "zustand": "5.0.8"
    },
    "devDependencies": {
        "@chromatic-com/storybook": "4.1.1",
        "@lhci/cli": "0.15.1",
        "@react-router/dev": "7.9.2",
        "@react-router/express": "7.9.2",
        "@react-router/fs-routes": "7.9.2",
        "@storybook/addon-a11y": "9.1.8",
        "@storybook/addon-docs": "9.1.8",
        "@storybook/addon-vitest": "9.1.8",
        "@storybook/react-vite": "9.1.8",
        "@tailwindcss/vite": "4.1.13",
        "@testing-library/jest-dom": "6.8.0",
        "@testing-library/react": "16.3.0",
        "@testing-library/user-event": "14.6.1",
        "@types/js-cookie": "3.0.6",
        "@types/lodash.debounce": "4.0.9",
        "@types/react": "19.1.13",
        "@types/react-dom": "19.1.9",
        "@vitejs/plugin-react": "5.0.3",
        "@vitest/browser": "3.2.4",
        "@vitest/coverage-v8": "3.2.4",
        "@vitest/ui": "3.2.4",
        "compression": "1.8.1",
        "cross-env": "10.0.0",
        "dotenv": "17.2.2",
        "eslint-plugin-storybook": "9.1.8",
        "express": "4.21.2",
        "get-port": "7.1.0",
        "http-proxy-middleware": "3.0.5",
        "jsdom": "27.0.0",
        "morgan": "1.10.1",
        "msw": "2.11.3",
        "playwright": "1.55.1",
        "rollup-plugin-visualizer": "6.0.4",
        "source-map-support": "0.5.21",
        "storybook": "9.1.8",
        "tw-animate-css": "1.4.0",
        "vite": "7.1.7",
        "vite-plugin-bundlesize": "0.3.0",
        "vite-plugin-devtools-json": "1.0.0",
        "vite-tsconfig-paths": "5.1.4",
        "vitest": "3.2.4"
    },
    "volta": {
        "node": "24.6.0",
        "pnpm": "10.16.1"
    },
    "bundlesize": {
        "server": [
            {
                "name": "**/*",
                "limit": "5 mB"
            }
        ],
        "client": [
            {
                "name": "assets/\\(package\\)-\\(commerce-sdk-isomorphic\\)-\\(lib\\)-index.esm.*.js",
                "limit": "454 kB"
            },
            {
                "name": "assets/\\(package\\)-\\(commerce-sdk-isomorphic\\)-\\(lib\\)-*.js",
                "limit": "160 kB"
            },
            {
                "name": "assets/\\(package\\)-\\(@react-router-dev\\)-\\(dist\\)-\\(config\\)-\\(defaults\\)-entry.client.*.js",
                "limit": "185 kB"
            },
            {
                "name": "assets/\\(package\\)-\\(react-router\\)-\\(dist\\)-\\(development\\)-chunk*.js",
                "limit": "125 kB"
            },
            {
                "name": "assets/\\(package\\)-\\(zod\\)-\\(v4\\)-\\(classic\\)-schemas.*.js",
                "limit": "55 kB"
            },
            {
                "name": "assets/\\(components\\)-\\(order-summary\\)-index.*.js",
                "limit": "65 kB"
            },
            {
                "name": "assets/\\(components\\)-\\(product-items-list\\)-index.*.js",
                "limit": "55 kB"
            },
            {
                "name": "assets/-root.*.js",
                "limit": "110 kB"
            },
            {
                "name": "assets/\\(package\\)-\\(@radix-ui-react-visually-hidden\\)-\\(dist\\)-index.*.js",
                "limit": "55 kB"
            },
            {
                "name": "**/*",
                "limit": "50 kB",
                "comment": "For every built JS chunk that exceeds the baseline limit, you must explicitly approve it above. We must try our best to minimize the bundle size. These are uncompressed numbers (before gzip/brotli)."
            }
        ]
    }
}
