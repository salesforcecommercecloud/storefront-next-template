{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "outDir": "./dist",
        "rootDir": "./src",
        "module": "ESNext",
        "target": "ES2022",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "strict": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "resolveJsonModule": true,
        "allowImportingTsExtensions": false,
        "jsx": "react-jsx",
        "tsBuildInfoFile": "./node_modules/.cache/storefront-next-runtime.tsbuildinfo",
        "paths": {
            "@/*": ["./src/*"]
        },
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"]
}
