#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/runner/work/storefront-next/storefront-next/packages/template-retail-rsc-app/node_modules/.pnpm/playwright@1.55.1/node_modules/playwright/node_modules:/home/runner/work/storefront-next/storefront-next/packages/template-retail-rsc-app/node_modules/.pnpm/playwright@1.55.1/node_modules:/home/runner/work/storefront-next/storefront-next/packages/template-retail-rsc-app/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/runner/work/storefront-next/storefront-next/packages/template-retail-rsc-app/node_modules/.pnpm/playwright@1.55.1/node_modules/playwright/node_modules:/home/runner/work/storefront-next/storefront-next/packages/template-retail-rsc-app/node_modules/.pnpm/playwright@1.55.1/node_modules:/home/runner/work/storefront-next/storefront-next/packages/template-retail-rsc-app/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../../node_modules/.pnpm/playwright@1.55.1/node_modules/playwright/cli.js" "$@"
else
  exec node  "$basedir/../../../../node_modules/.pnpm/playwright@1.55.1/node_modules/playwright/cli.js" "$@"
fi
