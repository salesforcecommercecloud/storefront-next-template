{
  "name": "@salesforce/storefront-next-dev",
  "version": "0.0.1",
  "description": "Dev and build tools for SFCC Storefront Next",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./react-router-preset": {
      "import": {
        "types": "./dist/configs/react-router.config.d.ts",
        "default": "./dist/configs/react-router.config.js"
      }
    },
    "./react-router/Scripts": {
      "import": {
        "types": "./dist/react-router/Scripts.d.ts",
        "default": "./dist/react-router/Scripts.js"
      }
    },
    "./push": {
      "import": {
        "types": "./dist/push.d.ts",
        "default": "./dist/push.js"
      }
    },
    "./mrt/ssr": {
      "import": {
        "types": "./dist/mrt/ssr.d.ts",
        "default": "./dist/mrt/ssr.js"
      },
      "require": {
        "types": "./dist/mrt/ssr.d.cts",
        "default": "./dist/mrt/ssr.cjs"
      }
    }
  },
  "bin": {
    "sfnext": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "pnpm typecheck && vitest --run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "clean": "rm -rf dist",
    "push": "node dist/cli.js push",
    "generate-cartridge": "node dist/cli.js generate-cartridge",
    "deploy-cartridge": "node dist/cli.js deploy-cartridge"
  },
  "keywords": [
    "vite",
    "plugin",
    "salesforce",
    "storefront-next",
    "commerce-cloud",
    "pwa-kit",
    "deployment",
    "bundle"
  ],
  "author": "cc-pwa-kit@salesforce.com",
  "license": "MIT",
  "peerDependencies": {
    "@react-router/dev": ">=7.0.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "react-router": ">=7.0.0",
    "vite": ">=7.0.0"
  },
  "devDependencies": {
    "@babel/parser": "^7.28.4",
    "@babel/traverse": "^7.28.4",
    "@babel/types": "7.28.4",
    "@react-router/dev": "7.9.2",
    "@types/archiver": "^6.0.2",
    "@types/babel__traverse": "7.28.0",
    "@types/express": "4.17.23",
    "@types/fs-extra": "^11.0.4",
    "@types/handlebars": "^4.1.0",
    "@types/jest": "30.0.0",
    "@types/minimatch": "^5.1.2",
    "@types/node": "^22.0.0",
    "@types/prompts": "2.4.9",
    "@types/react": "19.1.13",
    "@types/react-dom": "19.1.9",
    "@types/semver": "7.7.1",
    "@vitest/coverage-v8": "3.2.4",
    "fs-extra": "11.3.2",
    "jest": "^29.7.0",
    "memfs": "^4.42.0",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "react-router": "7.9.2",
    "ts-jest": "29.4.1",
    "tsdown": "^0.15.4",
    "tsx": "^4.19.2",
    "typescript": "^5.6.0",
    "vite": "7.1.7",
    "vitest": "3.2.4"
  },
  "dependencies": {
    "@react-router/express": "7.9.2",
    "archiver": "^7.0.1",
    "aws-serverless-express": "3.4.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "express": "4.21.2",
    "fs-extra": "^11.2.0",
    "handlebars": "4.7.8",
    "minimatch": "^10.0.1",
    "prompts": "2.4.2",
    "ts-morph": "^24.0.0",
    "undici": "^6.21.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
