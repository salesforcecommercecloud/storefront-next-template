{
  "name": "@salesforce/odyssey-dev",
  "version": "1.0.0",
  "description": "Bundle creation and deployment tool for SFCC Odyssey",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "odyssey-dev": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run clean && pnpm run build",
    "push": "node dist/cli.js push",
    "test": "pnpm run build && jest --runInBand --coverage --verbose --testLocationInResults --detectOpenHandles"
  },
  "keywords": [
    "salesforce",
    "commerce-cloud",
    "pwa-kit",
    "deployment",
    "bundle"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "archiver": "^7.0.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "fs-extra": "^11.2.0",
    "handlebars": "4.7.8",
    "minimatch": "^10.0.1"
  },
  "devDependencies": {
    "@babel/parser": "^7.28.4",
    "@babel/traverse": "^7.28.4",
    "@babel/types": "7.28.4",
    "@types/archiver": "^6.0.2",
    "@types/babel__parser": "7.1.5",
    "@types/babel__traverse": "7.28.0",
    "@types/fs-extra": "^11.0.4",
    "@types/handlebars": "^4.1.0",
    "@types/jest": "30.0.0",
    "@types/minimatch": "^5.1.2",
    "@types/node": "^22.0.0",
    "jest": "^29.7.0",
    "memfs": "^4.42.0",
    "ts-jest": "29.4.1",
    "tsdown": "^0.14.2",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
