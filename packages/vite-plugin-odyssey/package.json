{
  "name": "@salesforce/vite-plugin-odyssey",
  "version": "0.0.1",
  "description": "Vite plugin for Salesforce PWA Kit integration",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./react-router-preset": {
      "import": {
        "types": "./dist/configs/react-router.config.d.ts",
        "default": "./dist/configs/react-router.config.js"
      }
    },
    "./react-router/Scripts": {
      "import": {
        "types": "./dist/react-router/Scripts.d.ts",
        "default": "./dist/react-router/Scripts.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "pnpm typecheck && vitest --run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "vite",
    "plugin",
    "salesforce",
    "odyssey",
    "commerce"
  ],
  "author": "cc-pwa-kit@salesforce.com",
  "license": "MIT",
  "peerDependencies": {
    "@react-router/dev": ">=7.0.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "react-router": ">=7.0.0",
    "vite": ">=7.0.0"
  },
  "devDependencies": {
    "@react-router/dev": "7.9.2",
    "@types/express": "4.17.23",
    "@types/fs-extra": "11.0.4",
    "@types/react": "19.1.13",
    "@types/react-dom": "19.1.9",
    "@vitest/coverage-v8": "3.2.4",
    "fs-extra": "11.3.2",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "react-router": "7.9.2",
    "tsdown": "0.15.4",
    "vite": "7.1.7",
    "vitest": "3.2.4"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "dependencies": {
    "@react-router/express": "7.9.2",
    "aws-serverless-express": "3.4.0",
    "express": "4.21.2"
  }
}
