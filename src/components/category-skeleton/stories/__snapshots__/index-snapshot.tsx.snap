            data-slot="skeleton"
          />
          <div
            class="bg-accent animate-pulse rounded-md h-4 w-1/2"
            data-slot="skeleton"
          />
        </div>
      </div>
      <div
        class="border rounded-md"
      >
        <div
          class="p-4 border-b"
        >
          <div
            class="bg-accent animate-pulse rounded-md h-5 w-24"
            data-slot="skeleton"
          />
        </div>
        <div
          class="p-4 space-y-2"
        >
          <div
            class="bg-accent animate-pulse rounded-md h-4 w-full"
            data-slot="skeleton"
          />
          <div
            class="bg-accent animate-pulse rounded-md h-4 w-5/6"
            data-slot="skeleton"
          />
          <div
            class="bg-accent animate-pulse rounded-md h-4 w-2/3"
            data-slot="skeleton"
          />
        </div>
      </div>
    </div>
  </div>
</div>
`;
