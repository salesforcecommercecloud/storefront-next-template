                      class="animate-pulse rounded-md bg-muted h-6 w-20"
                    />
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div
          class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-4"
        >
          <div
            class="animate-pulse bg-muted h-10 w-10 rounded-full"
          />
        </div>
        <div
          class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-4"
        >
          <div
            class="animate-pulse bg-muted h-10 w-10 rounded-full"
          />
        </div>
      </div>
    </div>
  </div>
</div>
`;
