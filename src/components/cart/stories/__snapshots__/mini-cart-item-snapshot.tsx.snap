          Continue Shopping
        </button>
        <button
          class="w-full text-center text-sm text-primary hover:text-primary/80 transition-colors focus:outline-none focus:ring-2 focus:ring-ring rounded py-2"
          type="button"
        >
          View Cart
        </button>
      </div>
    </div>
  </div>
</div>
`;
