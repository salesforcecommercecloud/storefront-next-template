exports[`CartContent stories snapshot > DesktopLayout story renders and matches snapshot 1`] = `
<div>
  <div
    class="flex-1 min-h-screen bg-background mb-10"
    data-testid="sf-cart-container"
  >
    <div
      class="max-w-7xl mx-auto px-6"
    >
      <h1
        class="text-3xl font-semibold tracking-tight text-left my-6"
      >
        Cart (3 items)
      </h1>
      <div
        class="md:hidden mb-3"
      >
        <div
          class="border rounded-md bg-card px-5 py=3"
          data-orientation="vertical"
          data-slot="accordion"
        >
          <div
            class="border-b last:border-b-0"
            data-orientation="vertical"
            data-slot="accordion-item"
            data-state="closed"
          >
            <h3
              class="flex"
              data-orientation="vertical"
              data-state="closed"
            >
              <button
                aria-controls="radix-_r_1p_"
                aria-expanded="false"
                class="focus-visible:border-ring focus-visible:ring-ring/50 flex flex-1 items-start justify-between gap-4 rounded-md py-4 text-left font-medium transition-all outline-none hover:underline focus-visible:ring-[3px] disabled:pointer-events-none disabled:opacity-50 [&[data-state=open]>svg]:rotate-180 text-xl"
                data-orientation="vertical"
                data-radix-collection-item=""
                data-slot="accordion-trigger"
                data-state="closed"
                id="radix-_r_1o_"
                type="button"
              >
                Show order summary
                <svg
                  aria-hidden="true"
                  class="lucide lucide-chevron-down text-muted-foreground pointer-events-none size-4 shrink-0 translate-y-0.5 transition-transform duration-200"
                  fill="none"
                  height="24"
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  viewBox="0 0 24 24"
                  width="24"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    d="m6 9 6 6 6-6"
                  />
                </svg>
              </button>
            </h3>
            <div
              aria-labelledby="radix-_r_1o_"
              class="data-[state=closed]:animate-accordion-up data-[state=open]:animate-accordion-down overflow-hidden text-sm"
              data-orientation="vertical"
              data-slot="accordion-content"
              data-state="closed"
              hidden=""
              id="radix-_r_1p_"
              role="region"
              style="--radix-accordion-content-height: var(--radix-collapsible-content-height); --radix-accordion-content-width: var(--radix-collapsible-content-width);"
            />
          </div>
        </div>
      </div>
      <div
        class="grid grid-cols-1 lg:grid-cols-[66%_1fr] lg:gap-11"
      >
        <div
          class="md:order-2 lg:order-1"
        >
          <div
            class="md:p-8 p-3 border border-border rounded-lg shadow-sm mb-3"
          >
            <div
              class="space-y-4"
            >
              <div>
                <div
                  class="relative"
                  data-testid="sf-product-item-029407331227M"
                >
                  <div
                    class="bg-card text-card-foreground flex flex-col gap-6 rounded-xl p-0 border border-none shadow-none"
                    data-slot="card"
                  >
                    <div
                      class="px-3 py-4 md:px-6 md:py-7 relative overflow-hidden"
                      data-slot="card-content"
                    >
                      <div
                        class="grid md:grid-cols-[140px_1fr] grid-cols-[72px_1fr] gap-5 min-w-0"
                      >
                        <div
                          class="flex-shrink-0 flex items-center justify-center"
                        >
                          <div
                            class="bg-muted rounded flex-shrink-0 flex items-center justify-center aspect-square overflow-hidden md:w-32 w-16"
                          >
                            <img
                              alt="Solid Silk Tie, Navy, small"
                              class="h-full w-full object-contain"
                              src="https://edge.disstg.commercecloud.salesforce.com/dw/image/v2/ZZRF_001/on/demandware.static/-/Sites-apparel-m-catalog/default/dw7832203a/images/small/PG.949432114S.NAVYSI.PZ.webp?sfrm=jpg&q=80"
                            />
                          </div>
                        </div>
                        <div
                          class="flex-1 space-y-3 min-w-0"
                        >
                          <div
                            class="grid grid-cols-1 md:grid-cols-[3fr_2fr] gap-6 min-w-0"
                          >
                            <div
                              class="min-w-0"
                            >
                              <div
                                class="mb-4 flex items-start gap-2 min-w-0"
                              >
                                <h2
                                  class="font-semibold tracking-tight text-left text-xl min-w-0 flex-1 leading-tight"
                                >
                                  <a
                                    class="text-foreground hover:text-primary block break-words"
                                    href="/product/25752218M"
                                    title="Solid Silk Tie"
                                  >
                                    Solid Silk Tie
                                  </a>
                                </h2>
                              </div>
                              <div>
                                <div
                                  class="text-sm text-muted-foreground space-y-1 mb-1"
                                >
                                  <div>
                                    Color
                                    : 
                                    Navy
                                  </div>
                                </div>
                              </div>
