exports[`CartContent stories snapshot > CartWithPromotions story renders and matches snapshot 1`] = `
<div>
  <div
    class="flex-1 min-h-screen bg-background mb-10"
    data-testid="sf-cart-container"
  >
    <div
      class="max-w-7xl mx-auto px-6"
    >
      <h1
        class="text-3xl font-semibold tracking-tight text-left my-6 !text-lg !tracking-normal truncate"
      >
        My Cart (3 items)
      </h1>
      <div
        class="md:hidden mb-3"
      >
        <div
          class="bg-card text-card-foreground flex flex-col gap-6 rounded-xl border py-6 shadow-sm !py-4"
          data-slot="card"
        >
          <div
            class="px-[var(--cart-summary-px)]"
            data-slot="card-content"
          >
            <div
              class="space-y-4"
              data-testid="sf-order-summary"
            >
              <h2
                class="tracking-tight text-left text-base font-semibold text-foreground"
                id="order-summary-heading"
              >
                Order Summary
              </h2>
              <hr
                class="mx-[calc(var(--cart-summary-px)*-1)] border-border"
              />
              <div
                aria-labelledby="order-summary-heading"
                class="space-y-2"
                role="region"
              >
                <div
                  class="space-y-2 text-sm"
                >
                  <div
                    class="flex justify-between items-center"
                  >
                    <span>
                      Subtotal
                    </span>
                    <span>
                      $73.57
                    </span>
                  </div>
                  <div
                    class="flex justify-between items-center"
                  >
                    <div
                      class="flex items-center"
                    >
                      <span>
                        Shipping
                      </span>
                    </div>
                    <span
                      class="text-muted-foreground"
                    >
                      TBD
                    </span>
                  </div>
                  <div
                    class="flex justify-between items-center"
                  >
                    <span>
                      Tax
                    </span>
                    <span
                      class="text-muted-foreground"
                    >
                      TBD
                    </span>
                  </div>
                </div>
                <hr
                  class="mx-[calc(var(--cart-summary-px)*-1)] border-border"
                />
                <div
                  class="w-full"
                >
                  <div
                    class="mb-0"
                    data-orientation="vertical"
                    data-slot="accordion"
                  >
                    <div
                      class="border-b last:border-b-0"
                      data-orientation="vertical"
                      data-slot="accordion-item"
                      data-state="closed"
                    >
                      <h3
                        class="flex"
                        data-orientation="vertical"
                        data-state="closed"
                      >
                        <button
                          aria-controls="radix-_r_i_"
                          aria-expanded="false"
                          class="focus-visible:border-ring focus-visible:ring-ring/50 flex flex-1 items-start justify-between gap-4 rounded-md text-left text-sm font-medium transition-all outline-none hover:underline focus-visible:ring-[3px] disabled:pointer-events-none disabled:opacity-50 [&[data-state=open]>svg]:rotate-180 py-0"
                          data-orientation="vertical"
                          data-radix-collection-item=""
                          data-slot="accordion-trigger"
                          data-state="closed"
                          id="radix-_r_h_"
                          type="button"
                        >
                          <span
                            class="flex-1 text-left text-sm font-medium"
                          >
                            Do you have a promo code?
                          </span>
                          <svg
                            aria-hidden="true"
                            class="lucide lucide-chevron-down text-muted-foreground pointer-events-none size-4 shrink-0 translate-y-0.5 transition-transform duration-200"
                            fill="none"
                            height="24"
                            stroke="currentColor"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            viewBox="0 0 24 24"
                            width="24"
                            xmlns="http://www.w3.org/2000/svg"
                          >
                            <path
                              d="m6 9 6 6 6-6"
                            />
                          </svg>
                        </button>
                      </h3>
                      <div
                        aria-labelledby="radix-_r_h_"
                        class="data-[state=closed]:animate-accordion-up data-[state=open]:animate-accordion-down overflow-hidden text-sm"
                        data-orientation="vertical"
                        data-slot="accordion-content"
                        data-state="closed"
                        hidden=""
                        id="radix-_r_i_"
                        role="region"
                        style="--radix-accordion-content-height: var(--radix-collapsible-content-height); --radix-accordion-content-width: var(--radix-collapsible-content-width);"
                      />
                    </div>
                  </div>
                </div>
                <hr
                  class="mx-[calc(var(--cart-summary-px)*-1)] border-border"
                />
                <div
                  class="space-y-2 w-full text-sm pt-2"
                >
                  <div
                    class="flex w-full justify-between items-center"
                  >
                    <span
                      class="font-bold"
                    >
                      Estimated Total
                    </span>
                    <span
                      class="font-bold"
                    >
                      $73.57
                    </span>
                  </div>
                </div>
                <hr
                  class="mx-[calc(var(--cart-summary-px)*-1)] border-border"
                />
                <a
                  class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md font-medium transition-all disabled:pointer-events-none disabled:opacity-50 [&_svg]:pointer-events-none [&_svg:not([class*='size-'])]:size-4 shrink-0 [&_svg]:shrink-0 outline-none focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:ring-[3px] aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive bg-primary text-primary-foreground hover:bg-primary/90 h-9 px-4 py-2 has-[>svg]:px-3 w-full text-sm mt-2"
                  data-size="default"
                  data-slot="button"
                  data-variant="default"
                  href="/checkout"
                >
                  Proceed to Checkout
                  <svg
                    aria-label="Secure"
                    class="lucide lucide-lock ml-2 w-4 h-4"
                    fill="none"
                    height="24"
                    stroke="currentColor"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                    width="24"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <rect
                      height="11"
                      rx="2"
                      ry="2"
                      width="18"
                      x="3"
                      y="11"
                    />
                    <path
                      d="M7 11V7a5 5 0 0 1 10 0v4"
                    />
                  </svg>
                </a>
                <div
                  class="flex justify-center"
                >
                  <svg
                    class="mr-2"
