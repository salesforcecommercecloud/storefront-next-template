exports[`CartContent stories snapshot > EmptyCart story renders and matches snapshot 1`] = `
<div>
  <div
    class="bg-muted flex-1 min-w-full w-full"
    data-testid="sf-cart-empty"
  >
    <div
      class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 lg:py-14"
    >
      <div
        class="bg-background rounded-lg shadow-md p-8 md:p-16 text-center"
      >
        <svg
          aria-hidden="true"
          class="w-24 h-24 text-muted-foreground/30 mx-auto mb-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
          />
        </svg>
        <h2
          class="tracking-tight text-xl text-center font-semibold text-foreground mb-2"
        >
          Your cart is empty
        </h2>
        <p
          class="text-sm text-muted-foreground mb-8"
        >
          Start shopping to add items to your cart
        </p>
        <a
          class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium transition-all disabled:pointer-events-none disabled:opacity-50 [&_svg]:pointer-events-none [&_svg:not([class*='size-'])]:size-4 shrink-0 [&_svg]:shrink-0 outline-none focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:ring-[3px] aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive bg-primary text-primary-foreground hover:bg-primary/90 h-9 px-4 py-2 has-[>svg]:px-3"
          data-size="default"
          data-slot="button"
          data-variant="default"
          href="/"
        >
          Start Shopping
        </a>
      </div>
    </div>
  </div>
</div>
`;

exports[`CartContent stories snapshot > HighQuantityItem story renders and matches snapshot 1`] = `
<div>
  <div
    class="flex-1 min-h-screen bg-background mb-10"
    data-testid="sf-cart-container"
  >
    <div
      class="max-w-7xl mx-auto px-6"
    >
      <h1
        class="text-3xl font-semibold tracking-tight text-left my-6 !text-lg !tracking-normal truncate"
      >
        My Cart (10 items)
      </h1>
      <div
        class="md:hidden mb-3"
      >
        <div
          class="bg-card text-card-foreground flex flex-col gap-6 rounded-xl border py-6 shadow-sm !py-4"
          data-slot="card"
        >
          <div
            class="px-[var(--cart-summary-px)]"
            data-slot="card-content"
          >
            <div
              class="space-y-4"
              data-testid="sf-order-summary"
            >
              <h2
                class="tracking-tight text-left text-base font-semibold text-foreground"
                id="order-summary-heading"
              >
                Order Summary
              </h2>
              <hr
                class="mx-[calc(var(--cart-summary-px)*-1)] border-border"
              />
              <div
                aria-labelledby="order-summary-heading"
                class="space-y-2"
                role="region"
              >
                <div
                  class="space-y-2 text-sm"
                >
                  <div
                    class="flex justify-between items-center"
                  >
                    <span>
                      Subtotal
                    </span>
                    <span>
                      $39.67
                    </span>
                  </div>
                  <div
                    class="flex justify-between items-center"
                  >
                    <div
                      class="flex items-center"
                    >
                      <span>
                        Shipping
                      </span>
                    </div>
                    <span
                      class="text-muted-foreground"
                    >
                      TBD
                    </span>
                  </div>
                  <div
                    class="flex justify-between items-center"
                  >
                    <span>
                      Tax
                    </span>
                    <span
                      class="text-muted-foreground"
                    >
                      TBD
                    </span>
                  </div>
                </div>
                <hr
                  class="mx-[calc(var(--cart-summary-px)*-1)] border-border"
                />
                <div
                  class="w-full"
                >
                  <div
                    class="mb-0"
                    data-orientation="vertical"
                    data-slot="accordion"
                  >
                    <div
                      class="border-b last:border-b-0"
                      data-orientation="vertical"
                      data-slot="accordion-item"
                      data-state="closed"
                    >
                      <h3
                        class="flex"
                        data-orientation="vertical"
                        data-state="closed"
                      >
                        <button
                          aria-controls="radix-_r_3t_"
                          aria-expanded="false"
                          class="focus-visible:border-ring focus-visible:ring-ring/50 flex flex-1 items-start justify-between gap-4 rounded-md text-left text-sm font-medium transition-all outline-none hover:underline focus-visible:ring-[3px] disabled:pointer-events-none disabled:opacity-50 [&[data-state=open]>svg]:rotate-180 py-0"
                          data-orientation="vertical"
                          data-radix-collection-item=""
                          data-slot="accordion-trigger"
                          data-state="closed"
                          id="radix-_r_3s_"
                          type="button"
                        >
